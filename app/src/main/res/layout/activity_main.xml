<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="70dp"
    android:paddingBottom="24dp"
    android:background="@color/bg_dark">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Gestor de Tareas"
        android:textSize="30sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/accent_green"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnAddTask"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Agregar tarea"
        android:textAllCaps="false"
        android:textSize="17sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/text_dark"
        android:backgroundTint="@color/accent_green"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnMap"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Ver mi ubicación"
        android:textAllCaps="false"
        android:textSize="17sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/text_primary"
        android:backgroundTint="@color/card_dark"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnLogout"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Cerrar sesión"
        android:textAllCaps="false"
        android:textSize="17sp"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/text_dark"
        android:backgroundTint="@color/accent_olive"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tareas guardadas"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tvEmptyTasks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aún no tienes tareas registradas"
        android:textColor="@color/accent_olive"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/listTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/card_dark"
        android:dividerHeight="1dp" />

</LinearLayout>